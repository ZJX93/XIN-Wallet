# 数据库配置
DB_PASSWORD=xinwallet_secure_password_2026
DB_NAME=xinwallet

# 应用配置
APP_PORT=18888
JWT_SECRET=zhicai-super-secret-jwt-key-2026-fixed

# 加密密钥（用于 API Key / Secret 加密存储）
# 留空时：首次启动自动生成并持久化到 /app/data/.encryption-key
# 显式设置时：覆盖默认值（适合多实例共享同一密钥或 docker-compose down -v 后保留）
# 生成方式: openssl rand -hex 32
ENCRYPTION_KEY=

# 演示账号
ALLOW_DEMO=true
DEMO_PASSWORD=demo123456
DEV_PASSWORD=demo123456

# CORS 配置
CORS_ORIGIN=http://localhost:18888
