{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "semi": ["error", "always"],
    "quotes": ["warn", "single", { "avoidEscape": true }],
    "indent": ["warn", 4, { "SwitchCase": 1 }],
    "no-trailing-spaces": "warn",
    "comma-dangle": ["warn", "only-multiline"],
    "no-multiple-empty-lines": ["warn", { "max": 2 }]
  },
  "ignorePatterns": [
    "node_modules/",
    "vendor/",
    "*.min.js",
    "dist/",
    "build/"
  ],
  "overrides": [
    {
      "files": ["server/**/*.js"],
      "env": {
        "node": true,
        "browser": false
      }
    },
    {
      "files": ["js/**/*.js"],
      "env": {
        "browser": true,
        "node": false
      }
    }
  ]
}
